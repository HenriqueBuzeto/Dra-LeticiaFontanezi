# Frontend – API (Next.js usa rewrite de /api para o backend; opcional para absoluto)
NEXT_PUBLIC_API_URL=http://localhost:4000

# Dados de contato – use em produção para não colocar números/endereço no código
# NEXT_PUBLIC_DOCTOR_WHATSAPP=5511999999999
# NEXT_PUBLIC_DOCTOR_PHONE=1133334444
# NEXT_PUBLIC_DOCTOR_ADDRESS=São Paulo, SP

# Face API / AR (opcional)
# NEXT_PUBLIC_FACE_API_MODELS=/models

# Supabase – preencher na Vercel e em .env.local (nunca commitar valores reais)
# Obrigatório para login e "Esqueci minha senha": URL + Anon Key.
# NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_aqui
# Para o link de redefinição de senha funcionar, no Dashboard do Supabase:
#   Authentication → URL Configuration → Redirect URLs: adicione
#   https://seu-dominio.com/auth/reset-password  e  http://localhost:3000/auth/reset-password
# Service Role Key: só para scripts locais (ex.: criar admin). Nunca no frontend.
# SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui
