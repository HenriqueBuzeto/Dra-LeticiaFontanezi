# Frontend – API (Next.js usa rewrite de /api para o backend; opcional para absoluto)
NEXT_PUBLIC_API_URL=http://localhost:4000

# Dados de contato – use em produção para não colocar números/endereço no código
# NEXT_PUBLIC_DOCTOR_WHATSAPP=5511999999999
# NEXT_PUBLIC_DOCTOR_PHONE=1133334444
# NEXT_PUBLIC_DOCTOR_ADDRESS=São Paulo, SP

# Face API / AR (opcional)
# NEXT_PUBLIC_FACE_API_MODELS=/models

# Supabase – opcional (para uso direto do frontend no futuro)
# NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_aqui
