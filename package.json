{
  "name": "odontologico-premium",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "backend"
  ],
  "scripts": {
    "create-admin": "node scripts/create-admin-user.mjs",
    "check:secrets": "node scripts/check-secrets.mjs",
    "download:mediapipe": "node scripts/download-mediapipe.mjs",
    "download:face-api-models": "node scripts/download-face-api-models.mjs",
    "dev": "node --no-deprecation ./node_modules/next/dist/bin/next dev",
    "dev:backend": "cd backend && npm run start:dev",
    "dev:all": "concurrently -n backend,frontend -c blue,green \"npm run dev:backend\" \"npm run dev\"",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"app/**/*.{ts,tsx,css}\""
  },
  "dependencies": {
    "@headlessui/react": "^2.2.0",
    "@hookform/resolvers": "^3.9.1",
    "@mediapipe/camera_utils": "^0.3.1675466862",
    "@mediapipe/face_mesh": "^0.4.1633559619",
    "@react-three/drei": "^9.117.3",
    "@react-three/fiber": "^8.17.10",
    "@tensorflow/tfjs": "^4.22.0",
    "@tsparticles/engine": "^3.0.0",
    "@tsparticles/react": "^3.0.0",
    "@tsparticles/slim": "^3.0.0",
    "axios": "^1.7.7",
    "face-api.js": "^0.22.2",
    "framer-motion": "^11.11.17",
    "keen-slider": "^6.8.6",
    "lucide-react": "^0.460.0",
    "next": "^15.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitest/ui": "^4.0.18",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "eslint": "^9.15.0",
    "eslint-config-next": "^15.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "globals": "^15.11.0",
    "postcss": "^8.4.47",
    "prettier": "^3.3.3",
    "tailwindcss": "^3.4.14",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.11.0",
    "vitest": "^4.0.18"
  }
}
